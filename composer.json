{
  "name": "pmpr-cmn/wp-cmn-foundation",
  "type": "project",
  "license": "proprietary",
  "description": "Generic and reusable component for other wordpress packages and themes",
  "keywords": [
    "module",
    "generic",
    "reusable",
    "wordpress",
    "foundation"
  ],
  "require": {
    "php": ">=8.2",
    "twig/twig": "v3.0.5",
    "symfony/asset": "v5.4.3",
    "doctrine/dbal": "3.3.6",
    "doctrine/cache": "2.2.0",
    "narmafzam/cmb2": "dev-develop",
    "monolog/monolog": "2.9.3",
    "symfony/finder": "v5.4.3",
    "guzzlehttp/guzzle": "7.8.1",
    "symfony/dom-crawler": "v5.4.6",
    "symfony/filesystem": "v5.4.6",
    "symfony/css-selector": "v5.4.3",
    "illuminate/database": "v8.28.1",
    "illuminate/pagination": "v8.28.1",
    "mobiledetect/mobiledetectlib": "2.8.37",
    "wearerequired/wp-requirements-check": "1.1.0",
    "woocommerce/action-scheduler": "3.7.1",
    "google/apiclient": "^2.14.0"
  },
  "scripts": {
    "pre-autoload-dump": "Google\\Task\\Composer::cleanup"
  },
  "extra": {
    "google/apiclient-services": [
      "Gmail"
    ]
  },
  "prod-require": {
    "php": "8.2",
    "wordpress": "6.0"
  },
  "autoload": {
    "psr-4": {
      "Pmpr\\Common\\Foundation\\": "src/Pmpr/Common/Foundation"
    },
    "files": [
      "index.php"
    ]
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "tag": "1.4.71"
}
