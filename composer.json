{
  "name": "pmpr/common/wp-cmn-foundation",
  "type": "project",
  "license": "proprietary",
  "description": "Generic and reusable component for other wordpress packages and themes",
  "keywords": [
    "module",
    "generic",
    "reusable",
    "wordpress",
    "foundation"
  ],
  "require": {
    "php": ">=7.4",
    "twig/twig": "^v3.0.5",
    "symfony/asset": "^v5.2.0",
    "narmafzam/cmb2": "^v2.7.3",
    "monolog/monolog": "^2.2.0",
    "symfony/finder": "^v5.2.0",
    "guzzlehttp/guzzle": "^7.2",
    "symfony/dom-crawler": "^5.2",
    "symfony/filesystem": "^v5.2.0",
    "symfony/css-selector": "^5.2",
    "illuminate/database": "^v8.28.1",
    "enshrined/svg-sanitize": "^0.13.3",
    "illuminate/pagination": "^v8.28.1",
    "mobiledetect/mobiledetectlib": "^2.8.37",
    "wearerequired/wp-requirements-check": "^1.1.0"
  },
  "autoload": {
    "psr-4": {
      "Pmpr\\Common\\Foundation\\": "src/Pmpr/Common/Foundation"
    },
    "files": [
      "index.php"
    ]
  },
  "minimum-stability": "dev"
}
