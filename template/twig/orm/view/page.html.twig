<div class="wrap">
    {% if title %}
        <h1 class="wp-heading-inline">{{ title|raw }}</h1>
    {% endif %}
    {% if actions is defined
        and actions is not empty %}
        {% for action in actions %}

            <a {{ action.attrs|parse_attrs|raw }}>{{ action.title|raw }}</a>
        {% endfor %}
    {% endif %}

    <hr class="wp-header-end">
    {{ do_action('render_notices', 'orm-notice') }}
    {{ do_action('orm_page_before_content'|generate_hook, name) }}
    {{ do_action(('orm_' ~ name  ~ '_page_before_content')|generate_hook) }}
    {% block content %}{% endblock %}
</div>
