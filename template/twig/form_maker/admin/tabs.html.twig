<div class="pr-tabs">
    {% for tab in tabs %}
        {% set selectors = tab.getSelectors() %}
        <div id="{{ cmb_id|esc_attr }}-tab-{{ tab.getId()|esc_attr }}"
             class="pr-tab" data-fields="{{ selectors|esc_attr }}">
            {{ tab.getIconHtml()|raw }}
            {% set title = tab.getTitle() %}
            {% if title is not empty %}
                <span class="pr-tab-title">{{ title|raw }}</span>
            {% endif %}
        </div>
    {% endfor %}
</div>