{% set class_prefix = 'pr-sidebar' %}
<aside class="{{ class_prefix|esc_attr }}">
    <div class="{{ class_prefix|esc_attr }}-wrap">
        {% for id, section in sections %}
            <div class="{{ class_prefix|esc_attr }}-section">
                {{ section|call('render')|raw }}
            </div>
        {% endfor %}
    </div>
</aside>

