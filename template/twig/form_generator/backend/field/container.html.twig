{% extends get_template('./common', _self) %}

{% block before_field %}
    {% if title is not empty or description is not empty %}
        <header>
            {% if title is not empty %}
                {% include get_template('label', _self) with {
                    label: title,
                    for: attributes.id,
                    label_class: 'pr-field-label'
                } %}
            {% endif %}
            {% include get_template('../description', _self) %}
        </header>
    {% endif %}
{% endblock %}

{% block field_body %}
    {% include get_template('../../fields', _self) %}
{% endblock %}

